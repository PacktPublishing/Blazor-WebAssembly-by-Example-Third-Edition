@page "/"
@using Ch4_App.Shared

<PageTitle>Home</PageTitle>

<Alert Show="showAlert" OnOk="@(() => showAlert = false)">
    <h1>Alert</h1>
    <p>Today is @DateTime.Now.DayOfWeek.</p>
</Alert>
@if (!showAlert)
{
    <button @onclick="@(() => showAlert = true)">
        Show Alert
    </button>
}

@code {
    private bool showAlert = false;
}
