@page "/test-compare"
@inject IJSRuntime js
@implements IAsyncDisposable

<h2>Compare Texts</h2>
Use the ONNX model to compare the similarity between two text inputs. Use the "Reference Text" as the baseline and the "Candidate Text" as the text to compare against it. 
Click "Compare" to see the similarity score.
<br />
Use the <i>F12</i> key to open the browser's developer tools and view the <b>Console</b> output to view the tokens.
<hr />

<div class="mb-3">
    <label class="form-label">Reference Text</label>
    <InputTextArea class="form-control" rows="2" @bind-Value="referenceText" />
</div>
<div class="mb-3">
    <label class="form-label">Candidate Text</label>
    <InputTextArea class="form-control" rows="2" @bind-Value="candidateText" />
</div>
<button class="btn btn-primary" @onclick="Compare">Compare</button>
<hr />
<div class="alert alert-info">
    <strong>Similarity:</strong> @similarity.ToString("P2")
    <span class="badge bg-secondary ms-2">@similarity.ToString("F4")</span>
</div>

@code {
    private IJSObjectReference? _module;

    private string referenceText = "Hello World!";
    private string candidateText = "Hello World!";
    private decimal similarity = 1.0m;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await js.InvokeAsync<IJSObjectReference>("import", "./scripts/onnx.js");
            var success = await _module.InvokeAsync<bool>("initOnnx");
        }
    }

    public async Task Compare()
    {
        if (referenceText is null || candidateText is null)
        {
            similarity = 0;
            return;
        }

        similarity = await _module.InvokeAsync<decimal>("compare", referenceText, candidateText);
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            await _module.DisposeAsync();
        }
    }
}
